*.zjcdn.com = server:180.184.1.1

# --- Bilibili CDN — use AliDNS DoH for domestic CDN resolution ---
# dns.alidns.com 走代理 (surge Mac.conf 中 DOMAIN 规则)，DoH TLS 正常工作
