#!name=🟦 Local DNS Resolution 🧭
#!desc=Static DNS mappings for DoH servers + ByteDance CDN domains use Volcengine DNS for correct resolution
#!author=PafekutoBuru
#!category=🟦 PafekutoBuru
#!homepage=https://github.com/pafekutoburu/local-dns-resolution

# 原理:
# 1. DoH 服务器 [Host] 静态映射 → 打破 "解析域名要先连 DoH，连 DoH 又要先解析" 的循环依赖
# 2. ByteDance CDN 域名用火山引擎 DNS (180.184.1.1) 解析 → 拿到正确的国内 CDN IP
#    (Cloudflare DoH 返回的 IP 在某些网络环境下 TLS 握手失败)

[General]
use-local-host-item-for-proxy = true

[Host]
# --- Encrypted DNS (DoH) servers ---
dns.google = 8.8.8.8, 8.8.4.4, 2001:4860:4860::8888, 2001:4860:4860::8844
dns64.dns.google = 2001:4860:4860::6464, 2001:4860:4860::64
cloudflare-dns.com = 104.16.249.249, 104.16.248.249, 2606:4700::6810:f8f9, 2606:4700::6810:f9f9
1dot1dot1dot1.cloudflare-dns.com = 1.1.1.1, 1.0.0.1, 2606:4700:4700::1001, 2606:4700:4700::1111
one.one.one.one = 1.1.1.1, 1.0.0.1, 2606:4700:4700::1001, 2606:4700:4700::1111
# dns.alidns.com 已移除静态映射 — 让 Surge 全局 DoH 正确解析其 DoH 端点 IP
doh.pub = 1.12.12.21, 120.53.53.53
dot.pub = 1.12.12.21, 120.53.53.53
doh.360.cn = 111.7.73.60, 39.156.84.71, 221.181.72.233
dot.360.cn = 111.7.73.60, 39.156.84.71, 221.181.72.233
dns.twnic.tw = 101.101.101.101, 2001:de4::101, 2001:de4::102
ordns.he.net = 59.24.3.173, 2001:470:20::2

# --- Google FCM (Firebase Cloud Messaging) ---
talk.google.com = 108.177.125.188
mtalk.google.com = 108.177.125.188, 2404:6800:4008:c07::bc, 142.250.31.188
alt1-mtalk.google.com = 3.3.3.3, 2607:f8b0:4023:c0b::bc, 64.233.171.188
alt2-mtalk.google.com = 3.3.3.3, 142.250.115.188
alt3-mtalk.google.com = 74.125.200.188, 173.194.77.188
alt4-mtalk.google.com = 74.125.200.188, 173.194.219.188
alt5-mtalk.google.com = 3.3.3.3, 2607:f8b0:4023:1::bc, 142.250.112.188
alt6-mtalk.google.com = 3.3.3.3, 172.217.197.188
alt7-mtalk.google.com = 74.125.200.188, 2607:f8b0:4002:c03::bc, 108.177.12.188
alt8-mtalk.google.com = 3.3.3.3

# --- ByteDance CDN — use Volcengine DNS (180.184.1.1) for correct domestic CDN resolution ---
# refer: https://www.volcengine.com/docs/6758/179060
*.amemv.com = server:180.184.1.1
*.bdxiguaimg.com = server:180.184.1.1
*.bdxiguastatic.com = server:180.184.1.1
*.byted-static.com = server:180.184.1.1
